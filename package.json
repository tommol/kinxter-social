{
  "name": "kinxter-social",
  "version": "0.1.0",
  "description": "Kinxter Social monorepo.",
  "private": true,
  "scripts": {
    "auth:build": "dotnet build apps/auth/Kinxter.Auth.slnx",
    "auth:run": "dotnet run --project apps/auth/src/Kinxter.Auth/Kinxter.Auth.csproj",
    "api:build": "dotnet build apps/api/Kinxter.slnx",
    "api:run": "dotnet run --project apps/api/src/Kinxter.Api/Kinxter.Api.csproj",
    "admin:dev": "pnpm --filter @kinxter/admin dev",
    "admin:build": "pnpm --filter @kinxter/admin build",
    "admin:start": "pnpm --filter @kinxter/admin start",
    "web:dev": "pnpm --filter @kinxter/web dev",
    "web:build": "pnpm --filter @kinxter/web build",
    "web:start": "pnpm --filter @kinxter/web start",
    "test:functional": "node --test tests/functional/*.test.mjs",
    "containers:up": "podman compose -f deploy/containers/docker-compose.yml up --build",
    "containers:down": "podman compose -f deploy/containers/docker-compose.yml down"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.0"
}
