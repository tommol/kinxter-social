{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=15432;Database=kinxter_social;Username=kinxter;Password=kinxter;GSS Encryption Mode=Disable"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "ModuleEvents": {
    "Transport": "InProcess",
    "Nats": {
      "Url": "nats://localhost:4222",
      "StreamName": "KINXTER_MODULE_EVENTS",
      "SubjectPrefix": "kinxter.events",
      "ConsumerName": "kinxter-api",
      "MaxAckPending": 50,
      "MaxDeliver": 10,
      "AckWaitSeconds": 30,
      "ReconnectDelaySeconds": 5,
      "DuplicateWindowSeconds": 86400
    }
  }
}
